<Window x:Class="ApiTester.App.MockServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mock server" Width="720" Height="560" MinWidth="560" MinHeight="380"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg.Window}" Foreground="{DynamicResource Text.Soft}"
        FontFamily="{StaticResource Mono}" FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Height="40" Background="{DynamicResource Bg.Panel}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="&#x276F;" Foreground="{DynamicResource Accent}" FontWeight="Bold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="MOCK SERVER" Margin="9,0,0,0" FontWeight="Bold" FontSize="13"
                                   Foreground="{DynamicResource Text.Normal}" VerticalAlignment="Center"/>
                        <TextBlock Margin="12,0,0,0" FontSize="11" Foreground="{DynamicResource Text.Muted}"
                                   VerticalAlignment="Center" Text="a standing local endpoint to fire requests at"/>
                    </StackPanel>
                    <Button Content="&#xE8BB;" HorizontalAlignment="Right" Style="{StaticResource CaptionClose}"
                            Height="40" Click="Close_Click" ToolTip="Close"/>
                </Grid>
            </Border>

            <!-- Controls -->
            <DockPanel Grid.Row="1" Margin="14,12,14,4">
                <TextBlock Text="MODE" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                <ComboBox x:Name="ModeCombo" Width="150" SelectedIndex="0" DockPanel.Dock="Left">
                    <ComboBoxItem>Plain HTTP</ComboBoxItem>
                    <ComboBoxItem>HTTPS (TLS)</ComboBoxItem>
                    <ComboBoxItem>Mutual TLS</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="PORT" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="14,0,7,0" DockPanel.Dock="Left"/>
                <TextBox x:Name="PortBox" Width="72" DockPanel.Dock="Left" VerticalContentAlignment="Center"
                         Padding="8,6" Text="8770" ToolTip="Port to listen on (0 picks a free port)"/>
                <Button x:Name="StartButton" DockPanel.Dock="Right" Content="Start" Width="90" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}" Click="Start_Click"/>
                <Button x:Name="StopButton" DockPanel.Dock="Right" Content="Stop" Width="90" Margin="8,0,0,0"
                        IsEnabled="False" Click="Stop_Click"/>
                <TextBlock/>
            </DockPanel>

            <!-- Status -->
            <Border Grid.Row="2" Margin="14,8,14,4" Background="{DynamicResource Bg.Input}" BorderBrush="{DynamicResource Border}"
                    BorderThickness="1" CornerRadius="6" Padding="12,10">
                <StackPanel>
                    <DockPanel>
                        <Button x:Name="CopyUrlButton" DockPanel.Dock="Right" Content="Copy URL" Width="90" Margin="8,0,0,0"
                                IsEnabled="False" Click="CopyUrl_Click"/>
                        <Button x:Name="OpenCertsButton" DockPanel.Dock="Right" Content="Open certs" Width="94"
                                Visibility="Collapsed" Click="OpenCerts_Click"/>
                        <TextBox x:Name="UrlBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource Text.Muted}" VerticalContentAlignment="Center"
                                 Text="stopped — pick a mode and press Start"/>
                    </DockPanel>
                    <TextBlock x:Name="RoutesText" FontSize="11" Foreground="{DynamicResource Text.Muted}" Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="routes:  /  ·  /status/&lt;code&gt;  ·  /sse  ·  /token  ·  /windows-auth  ·  WebSocket on any path"/>
                    <TextBlock x:Name="CertText" FontSize="11" Foreground="{DynamicResource Text.Faint}" Margin="0,4,0,0"
                               TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Request log -->
            <TextBox x:Name="LogBox" Grid.Row="3" Margin="14,6,14,14" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Background="{DynamicResource Bg.Input}" Foreground="{DynamicResource Text.Soft}"
                     BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="10"/>
        </Grid>
    </Border>
</Window>
