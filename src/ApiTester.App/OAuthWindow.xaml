<Window x:Class="ApiTester.App.OAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Get OAuth token" Width="620" SizeToContent="Height" MaxHeight="720"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg.Window}" Foreground="{DynamicResource Text.Soft}"
        FontFamily="{StaticResource Mono}" FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1">
        <StackPanel>
            <Border Height="40" Background="{DynamicResource Bg.Panel}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="&#x276F;" Foreground="{DynamicResource Accent}" FontWeight="Bold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="GET OAUTH 2.0 TOKEN" Margin="9,0,0,0" FontWeight="Bold" FontSize="13"
                                   Foreground="{DynamicResource Text.Normal}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="&#xE8BB;" HorizontalAlignment="Right" Style="{StaticResource CaptionClose}"
                            Height="40" Click="Close_Click" ToolTip="Close"/>
                </Grid>
            </Border>

            <StackPanel Margin="16,14,16,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="GRANT" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="GrantCombo" SelectedIndex="0" Margin="0,0,0,8"
                              SelectionChanged="GrantCombo_SelectionChanged">
                        <ComboBoxItem>Client credentials</ComboBoxItem>
                        <ComboBoxItem>Password</ComboBoxItem>
                        <ComboBoxItem>Refresh token</ComboBoxItem>
                        <ComboBoxItem>Authorization code (opens your browser)</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="TOKEN URL" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TokenUrlBox" VerticalContentAlignment="Center"
                             Padding="8,6" Tag="https://auth.example.com/oauth/token"/>
                </Grid>

                <StackPanel x:Name="AuthUrlPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AUTHORIZE URL" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="AuthUrlBox" VerticalContentAlignment="Center" Padding="8,6"
                                 Tag="https://auth.example.com/oauth/authorize"/>
                    </Grid>
                    <TextBlock Foreground="{DynamicResource Text.Faint}" FontSize="11" Margin="120,4,0,0" TextWrapping="Wrap"
                               Text="Your browser opens to sign in; the redirect is caught on a temporary http://127.0.0.1 port with PKCE."/>
                </StackPanel>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CLIENT ID" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ClientIdBox" VerticalContentAlignment="Center" Padding="8,6" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CLIENT SECRET" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ClientSecretBox" VerticalContentAlignment="Center" Padding="8,6" Margin="0,0,0,8"
                             Tag="leave blank for a public client"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="SEND CREDS" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ClientAuthCombo" SelectedIndex="0">
                        <ComboBoxItem>In the request body</ComboBoxItem>
                        <ComboBoxItem>As a Basic auth header</ComboBoxItem>
                    </ComboBox>
                </Grid>

                <StackPanel x:Name="PasswordPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="USERNAME" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="UsernameBox" VerticalContentAlignment="Center" Padding="8,6" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="PASSWORD" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" VerticalContentAlignment="Center" Padding="8,6"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="RefreshPanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="REFRESH TOKEN" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="RefreshTokenBox" VerticalContentAlignment="Center" Padding="8,6"/>
                    </Grid>
                </StackPanel>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SCOPE" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="ScopeBox" VerticalContentAlignment="Center" Padding="8,6" Margin="0,0,0,8"
                             Tag="space-separated, e.g. api.read api.write"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="APPLY TO" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ApplyToBox" VerticalContentAlignment="Center" Padding="8,6"
                             Tag="API URL the token is for, e.g. https://api.example.com"/>
                </Grid>

                <Border x:Name="StatusBar" Background="{DynamicResource Bg.Input}" BorderBrush="{DynamicResource Border}"
                        BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,14,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="{DynamicResource Text.Soft}"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Width="96" Margin="0,0,8,0" Click="Close_Click"/>
                    <Button x:Name="FetchButton" Content="Fetch token" Width="130" Style="{StaticResource PrimaryButton}"
                            Click="Fetch_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
