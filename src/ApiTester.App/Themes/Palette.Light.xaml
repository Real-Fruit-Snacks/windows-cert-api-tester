<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Terminal Workbench palette (light) ============ -->
    <!-- Same keys as the dark palette in TerminalWorkbench.xaml. This dictionary is
         merged over the base palette at runtime; every palette reference is a
         DynamicResource, so adding/removing this overlay repaints the whole UI live. -->
    <SolidColorBrush x:Key="Bg.Window"   Color="#eef1f0"/>
    <SolidColorBrush x:Key="Bg.Panel"    Color="#ffffff"/>
    <SolidColorBrush x:Key="Bg.Input"    Color="#f6f8f7"/>
    <SolidColorBrush x:Key="Bg.Raised"   Color="#e3e9e6"/>
    <SolidColorBrush x:Key="Border"        Color="#d3dbd7"/>
    <SolidColorBrush x:Key="Border.Strong" Color="#b4c0ba"/>
    <SolidColorBrush x:Key="Accent"      Color="#0e9c62"/>
    <SolidColorBrush x:Key="Accent.Alt"  Color="#1785a8"/>
    <SolidColorBrush x:Key="Warm"        Color="#a9761a"/>
    <SolidColorBrush x:Key="Text.Normal" Color="#16201c"/>
    <SolidColorBrush x:Key="Text.Soft"   Color="#33413b"/>
    <SolidColorBrush x:Key="Text.Muted"  Color="#5c6b64"/>
    <SolidColorBrush x:Key="Text.Faint"  Color="#8a968f"/>
    <SolidColorBrush x:Key="Text.OnAccent" Color="#ffffff"/>
    <SolidColorBrush x:Key="Red"         Color="#cf3341"/>

</ResourceDictionary>
