<Window x:Class="ApiTester.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Certificate API Tester" Height="740" Width="1140" MinWidth="900"
        Background="{StaticResource Bg.Window}"
        Foreground="{StaticResource Text.Soft}"
        FontFamily="{StaticResource Mono}"
        FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <DockPanel>

        <!-- ============ header bar ============ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,11">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource Text.Faint}" FontSize="11" Text="WINDOWS &#183; .NET 9 &#183; mTLS"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x276F;" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="CERTIFICATE API TESTER" VerticalAlignment="Center" Margin="9,0,0,0"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource Text.Normal}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============ body ============ -->
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Certificate row -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="CERTIFICATE" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="92"/>
                <ComboBox x:Name="CertCombo" Width="600" DisplayMemberPath="."/>
                <Button x:Name="RefreshCertsButton" Content="Refresh" Width="84" Margin="8,0,0,0"
                        Click="RefreshCertsButton_Click"/>
                <CheckBox x:Name="IgnoreServerCertCheck" Content="Ignore server cert errors (insecure)"
                          VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- Request line -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                <ComboBox x:Name="MethodCombo" Width="92" SelectedIndex="0">
                    <ComboBoxItem>GET</ComboBoxItem>
                    <ComboBoxItem>POST</ComboBoxItem>
                    <ComboBoxItem>PUT</ComboBoxItem>
                    <ComboBoxItem>PATCH</ComboBoxItem>
                    <ComboBoxItem>DELETE</ComboBoxItem>
                    <ComboBoxItem>HEAD</ComboBoxItem>
                    <ComboBoxItem>OPTIONS</ComboBoxItem>
                </ComboBox>
                <TextBox x:Name="UrlBox" Width="840" Margin="8,0,0,0" VerticalContentAlignment="Center"/>
                <Button x:Name="SendButton" Content="Send" Width="94" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}" Click="SendButton_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="2" Text="HEADERS &#8212; ONE PER LINE (NAME: VALUE)" Style="{StaticResource Caption}" Margin="2,6,0,3"/>
            <TextBox Grid.Row="3" x:Name="HeadersBox" AcceptsReturn="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="62"/>

            <TextBlock Grid.Row="4" Text="REQUEST &amp; RESPONSE" Style="{StaticResource Caption}" Margin="2,10,0,4"/>
            <TabControl Grid.Row="5" Margin="0,0,0,8">
                <TabItem Header="Request Body">
                    <TextBox x:Name="BodyBox" AcceptsReturn="True" TextWrapping="NoWrap" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                </TabItem>
                <TabItem Header="Response (Pretty)">
                    <TextBox x:Name="PrettyBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                </TabItem>
                <TabItem Header="Response (Raw)">
                    <TextBox x:Name="RawBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                </TabItem>
                <TabItem Header="Response Headers">
                    <TextBox x:Name="ResponseHeadersBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                </TabItem>
            </TabControl>

            <!-- Status bar + action buttons -->
            <Border Grid.Row="6" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <DockPanel>
                    <Button x:Name="SelfTestButton" Content="Run Self-Test" Width="118"
                            DockPanel.Dock="Right" Click="SelfTestButton_Click"/>
                    <Button x:Name="SaveResponseButton" Content="Save Response…" Width="128" Margin="0,0,8,0"
                            DockPanel.Dock="Right" Click="SaveResponseButton_Click"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource Text.Soft}" Text="Ready."/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
