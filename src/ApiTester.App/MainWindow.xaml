<Window x:Class="ApiTester.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Certificate API Tester" Height="780" Width="1180" MinWidth="960" MinHeight="600"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None"
        Background="{StaticResource Bg.Window}"
        Foreground="{StaticResource Text.Soft}"
        FontFamily="{StaticResource Mono}"
        FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <DockPanel x:Name="RootContainer">

        <!-- ============ title bar ============ -->
        <Border DockPanel.Dock="Top" Height="44" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="HistoryToggle" Style="{StaticResource CaptionButton}" Height="44"
                        Content="&#xE700;" Click="HistoryToggle_Click" ToolTip="Toggle history (Ctrl+H)"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="&#x276F;" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="CERTIFICATE API TESTER" VerticalAlignment="Center" Margin="9,0,0,0"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource Text.Normal}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="ENV" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <ComboBox x:Name="EnvCombo" Width="150" Height="26" SelectionChanged="EnvCombo_SelectionChanged"
                              ToolTip="Active environment — its {{variables}} are substituted when you send."/>
                    <Button x:Name="ManageEnvButton" Content="Edit" Height="26" FontSize="11" Padding="9,0"
                            Margin="6,0,14,0" Click="ManageEnvButton_Click" ToolTip="Manage environments and variables"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Text.Faint}" FontSize="11"
                               Text="WINDOWS &#183; .NET 9 &#183; mTLS"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Height="44"
                            Content="&#xE921;" Click="MinButton_Click" ToolTip="Minimize"/>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Height="44"
                            Content="&#xE922;" Click="MaxButton_Click" ToolTip="Maximize"/>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionClose}" Height="44"
                            Content="&#xE8BB;" Click="CloseButton_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ history sidebar ============ -->
        <Border x:Name="HistoryPanel" DockPanel.Dock="Left" Width="250" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Height="38">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="HistoryTabButton" Content="HISTORY" Style="{StaticResource SideTab}"
                                Tag="active" Click="ShowHistory_Click"/>
                        <Button x:Name="CollectionsTabButton" Content="COLLECTIONS" Style="{StaticResource SideTab}"
                                Margin="14,0,0,0" Click="ShowCollections_Click"/>
                    </StackPanel>
                    <Button x:Name="ClearHistoryButton" Content="Clear" Height="24" FontSize="11" Padding="10,0"
                            HorizontalAlignment="Right" Margin="0,0,10,0" Click="ClearHistoryButton_Click"/>
                </Grid>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Border}"/>
                <Grid>
                    <ListBox x:Name="HistoryList" SelectionChanged="HistoryList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Method}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource Text.Normal}" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayHost}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Text.Faint}" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel x:Name="CollectionsArea" Visibility="Collapsed">
                        <StackPanel DockPanel.Dock="Bottom" Margin="8" >
                            <Button x:Name="SaveToCollectionButton" Content="Save current request…" Height="28"
                                    Click="SaveToCollectionButton_Click" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="NewFolderButton" Content="+ Folder" Height="26" FontSize="11" Padding="9,0"
                                        Click="NewFolderButton_Click"/>
                                <Button x:Name="RenameNodeButton" Content="Rename" Height="26" FontSize="11" Padding="9,0"
                                        Margin="6,0,0,0" Click="RenameNodeButton_Click"/>
                                <Button x:Name="DeleteNodeButton" Content="Delete" Height="26" FontSize="11" Padding="9,0"
                                        Margin="6,0,0,0" Click="DeleteNodeButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock x:Name="CollectionsEmptyHint" DockPanel.Dock="Top" Margin="14,14,14,0"
                                   Foreground="{StaticResource Text.Faint}" FontSize="11" TextWrapping="Wrap"
                                   Text="No saved requests yet. Send a request, then “Save current request…” to keep it here."/>
                        <TreeView x:Name="CollectionsTree" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MouseDoubleClick="CollectionsTree_MouseDoubleClick">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding MethodBadge}" FontSize="10" FontWeight="Bold" MinWidth="30"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text.Normal}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ============ main area ============ -->
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>                <!-- request tab strip -->
                <RowDefinition Height="Auto"/>                <!-- website -->
                <RowDefinition Height="Auto"/>                <!-- certificate -->
                <RowDefinition Height="Auto"/>                <!-- request line -->
                <RowDefinition Height="*" MinHeight="130"/>   <!-- request config -->
                <RowDefinition Height="Auto"/>                <!-- splitter -->
                <RowDefinition Height="2*" MinHeight="170"/>  <!-- response -->
                <RowDefinition Height="Auto"/>                <!-- status -->
            </Grid.RowDefinitions>

            <!-- request tab strip -->
            <DockPanel Grid.Row="0" Margin="0,0,0,0">
                <Button x:Name="NewTabButton" DockPanel.Dock="Right" Content="&#xFF0B;" Width="34"
                        VerticalAlignment="Bottom" Margin="4,0,0,0" Click="NewTabButton_Click"
                        ToolTip="New request tab (Ctrl+T)"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="TabStrip" Style="{StaticResource TabStripList}" VerticalAlignment="Bottom"
                             SelectionChanged="TabStrip_SelectionChanged"
                             ItemContainerStyle="{StaticResource TabStripItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="12,6,7,6">
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" MaxWidth="190"
                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource Text.Soft}"/>
                                    <Button Content="&#x2715;" Tag="{Binding}" Click="CloseTab_Click"
                                            Style="{StaticResource MiniButton}" Width="20" Height="20" Margin="9,0,0,0"
                                            FontSize="11" ToolTip="Close tab (Ctrl+W)"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- website (base URL) row -->
            <DockPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="WEBSITE" Style="{StaticResource Caption}" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Width="92"/>
                <ComboBox x:Name="SavedBasesCombo" DockPanel.Dock="Right" Width="190" Margin="8,0,0,0"
                          SelectionChanged="SavedBasesCombo_SelectionChanged"/>
                <Button x:Name="ForgetBaseButton" DockPanel.Dock="Right" Content="Forget" Width="74" Margin="8,0,0,0"
                        Click="ForgetBaseButton_Click"/>
                <TextBox x:Name="BaseUrlBox" VerticalContentAlignment="Center"
                         Tag="https://internal.corp   (optional base URL)"
                         ToolTip="Base URL, e.g. https://internal.corp — the URL box below is appended to this. Leave blank to type full URLs."/>
            </DockPanel>

            <!-- cert row -->
            <DockPanel Grid.Row="2" Margin="0,0,0,8">
                <TextBlock Text="CERTIFICATE" Style="{StaticResource Caption}" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Width="92"/>
                <CheckBox x:Name="IgnoreServerCertCheck" DockPanel.Dock="Right"
                          Content="Ignore server cert errors (insecure)" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button x:Name="RefreshCertsButton" DockPanel.Dock="Right" Content="Refresh" Width="82" Margin="8,0,0,0"
                        Click="RefreshCertsButton_Click"/>
                <TextBox x:Name="CertFilter" DockPanel.Dock="Right" Width="140" Margin="8,0,0,0" Tag="filter…"
                         VerticalContentAlignment="Center" ToolTip="Filter certificates" TextChanged="CertFilter_TextChanged"/>
                <ComboBox x:Name="CertCombo" DisplayMemberPath="."/>
            </DockPanel>

            <!-- request line -->
            <DockPanel Grid.Row="3" Margin="0,0,0,8">
                <ComboBox x:Name="MethodCombo" DockPanel.Dock="Left" Width="92" SelectedIndex="0" Margin="0,0,8,0"
                          SelectionChanged="MethodCombo_SelectionChanged">
                    <ComboBoxItem>GET</ComboBoxItem>
                    <ComboBoxItem>POST</ComboBoxItem>
                    <ComboBoxItem>PUT</ComboBoxItem>
                    <ComboBoxItem>PATCH</ComboBoxItem>
                    <ComboBoxItem>DELETE</ComboBoxItem>
                    <ComboBoxItem>HEAD</ComboBoxItem>
                    <ComboBoxItem>OPTIONS</ComboBoxItem>
                </ComboBox>
                <Button x:Name="SendButton" DockPanel.Dock="Right" Content="Send" Width="94" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}" Click="SendButton_Click"/>
                <Button x:Name="CancelButton" DockPanel.Dock="Right" Content="Cancel" Width="78" Margin="8,0,0,0"
                        IsEnabled="False" Click="CancelButton_Click"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <TextBlock Text="TIMEOUT" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TimeoutBox" Width="56" Margin="6,0,0,0" Text="100"
                             VerticalContentAlignment="Center" ToolTip="Request timeout (seconds)"/>
                    <TextBlock Text="s" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{StaticResource Text.Muted}"/>
                </StackPanel>
                <TextBox x:Name="UrlBox" VerticalContentAlignment="Center" KeyDown="UrlBox_KeyDown"
                         TextChanged="UrlBox_TextChanged" LostFocus="UrlBox_LostFocus"
                         Tag="/api/resource   or a full https://… URL"
                         ToolTip="Path appended to the website above (e.g. /api/thing), or a full URL if no website is set."/>
            </DockPanel>

            <!-- request config tabs -->
            <TabControl Grid.Row="4">
                <TabItem Header="Params">
                    <DockPanel Margin="2">
                        <Button DockPanel.Dock="Bottom" x:Name="AddParamButton" Content="+ Add parameter" Width="140"
                                HorizontalAlignment="Left" Margin="8" Click="AddParamButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ParamsItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="key" VerticalContentAlignment="Center" ToolTip="Parameter name"/>
                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="value" Margin="6,0,0,0" VerticalContentAlignment="Center" ToolTip="Parameter value"/>
                                            <Button Grid.Column="3" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveParamButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Headers">
                    <DockPanel Margin="2">
                        <Button DockPanel.Dock="Bottom" x:Name="AddHeaderButton" Content="+ Add header" Width="120"
                                HorizontalAlignment="Left" Margin="8" Click="AddHeaderButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HeadersItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="Accept" VerticalContentAlignment="Center" ToolTip="Header name"/>
                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="application/json" Margin="6,0,0,0" VerticalContentAlignment="Center" ToolTip="Header value"/>
                                            <Button Grid.Column="3" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveHeaderButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Body">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="CONTENT-TYPE" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ContentTypeCombo" Width="260" Margin="8,0,0,0" SelectedIndex="0">
                                <ComboBoxItem>application/json</ComboBoxItem>
                                <ComboBoxItem>application/xml</ComboBoxItem>
                                <ComboBoxItem>text/plain</ComboBoxItem>
                                <ComboBoxItem>application/x-www-form-urlencoded</ComboBoxItem>
                                <ComboBoxItem>(none)</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <TextBox x:Name="BodyBox" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                 Tag="{}{ &quot;example&quot;: &quot;request body&quot; }"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Auth">
                    <StackPanel Margin="12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="TYPE" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="AuthTypeCombo" Width="180" SelectedIndex="0"
                                      SelectionChanged="AuthTypeCombo_SelectionChanged">
                                <ComboBoxItem>None</ComboBoxItem>
                                <ComboBoxItem>Bearer token</ComboBoxItem>
                                <ComboBoxItem>Basic</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="BearerPanel" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                            <TextBlock Text="TOKEN" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                            <TextBox x:Name="BearerTokenBox" Width="520" VerticalContentAlignment="Center"
                                     Tag="paste your bearer token"/>
                        </StackPanel>
                        <StackPanel x:Name="BasicPanel" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="USER" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="BasicUserBox" Width="260" VerticalContentAlignment="Center" Tag="username"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PASS" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="BasicPassBox" Width="260" VerticalContentAlignment="Center" Tag="password"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="5" Height="6" HorizontalAlignment="Stretch" Background="Transparent"
                          VerticalAlignment="Center"/>

            <!-- response -->
            <DockPanel Grid.Row="6">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="RESPONSE" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CopyBodyButton" Content="Copy body" Height="26" FontSize="11" Padding="10,0"
                                Margin="0,0,6,0" Click="CopyBodyButton_Click"/>
                        <Button x:Name="CopyCurlButton" Content="Copy as cURL" Height="26" FontSize="11" Padding="10,0"
                                Margin="0,0,6,0" Click="CopyCurlButton_Click"/>
                        <Button x:Name="SaveResponseButton" Content="Save…" Height="26" FontSize="11" Padding="10,0"
                                Click="SaveResponseButton_Click"/>
                    </StackPanel>
                </Grid>
                <TabControl>
                    <TabItem Header="Pretty">
                        <RichTextBox x:Name="PrettyRich" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"/>
                    </TabItem>
                    <TabItem Header="Raw">
                        <TextBox x:Name="RawBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="The raw response body appears here after you send a request."
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                    <TabItem Header="Headers">
                        <TextBox x:Name="ResponseHeadersBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="Response headers appear here after you send a request."
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <TextBox x:Name="DiagnosticsBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="TLS and certificate details appear here after a request."
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                </TabControl>
            </DockPanel>

            <!-- status bar -->
            <Border Grid.Row="7" Margin="0,8,0,0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <DockPanel>
                    <Button x:Name="SelfTestButton" Content="Run Self-Test" Width="118"
                            DockPanel.Dock="Right" Click="SelfTestButton_Click"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource Text.Soft}"
                               TextTrimming="CharacterEllipsis" Text="Ready."/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
