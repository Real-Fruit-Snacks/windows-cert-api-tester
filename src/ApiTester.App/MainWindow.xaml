<Window x:Class="ApiTester.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:ApiTester.App"
        Title="Certificate API Tester" Height="780" Width="1180" MinWidth="960" MinHeight="600"
        Icon="pack://application:,,,/icon.ico"
        WindowStyle="None"
        Background="{StaticResource Bg.Window}"
        Foreground="{StaticResource Text.Soft}"
        FontFamily="{StaticResource Mono}"
        FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="1" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:StatusToBrushConverter x:Key="StatusBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:CaptureSourceConverter x:Key="CaptureSourceConverter"/>
        <local:AssertTargetConverter x:Key="AssertTargetConverter"/>
        <local:AssertOpConverter x:Key="AssertOpConverter"/>
    </Window.Resources>

    <DockPanel x:Name="RootContainer">

        <!-- ============ title bar ============ -->
        <Border DockPanel.Dock="Top" Height="44" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="HistoryToggle" Style="{StaticResource CaptionButton}" Height="44"
                        Content="&#xE700;" Click="HistoryToggle_Click" ToolTip="Toggle history (Ctrl+H)"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <TextBlock Text="&#x276F;" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="CERTIFICATE API TESTER" VerticalAlignment="Center" Margin="9,0,0,0"
                               FontWeight="Bold" FontSize="13" Foreground="{StaticResource Text.Normal}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="ENV" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <ComboBox x:Name="EnvCombo" Width="188" Height="26" SelectionChanged="EnvCombo_SelectionChanged"
                              ToolTip="Active environment — its {{variables}} are substituted when you send."/>
                    <Button x:Name="ManageEnvButton" Content="Edit" Height="26" FontSize="11" Padding="9,0"
                            Margin="6,0,14,0" Click="ManageEnvButton_Click" ToolTip="Manage environments and variables"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Text.Faint}" FontSize="11"
                               Text="WINDOWS &#183; .NET 9 &#183; mTLS"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="HelpButton" Style="{StaticResource CaptionButton}" Height="44"
                            Content="&#xE897;" Click="HelpButton_Click" ToolTip="Help (F1)"/>
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Height="44"
                            Content="&#xE921;" Click="MinButton_Click" ToolTip="Minimize"/>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Height="44"
                            Content="&#xE922;" Click="MaxButton_Click" ToolTip="Maximize"/>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionClose}" Height="44"
                            Content="&#xE8BB;" Click="CloseButton_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ history sidebar ============ -->
        <Border x:Name="HistoryPanel" DockPanel.Dock="Left" Width="250" Background="{StaticResource Bg.Panel}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Height="38">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="HistoryTabButton" Content="HISTORY" Style="{StaticResource SideTab}"
                                Tag="active" Click="ShowHistory_Click"/>
                        <Button x:Name="CollectionsTabButton" Content="COLLECTIONS" Style="{StaticResource SideTab}"
                                Margin="14,0,0,0" Click="ShowCollections_Click"/>
                    </StackPanel>
                    <Button x:Name="ClearHistoryButton" Content="Clear" Height="24" FontSize="11" Padding="10,0"
                            HorizontalAlignment="Right" Margin="0,0,10,0" Click="ClearHistoryButton_Click"/>
                </Grid>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Border}"/>
                <Grid>
                    <ListBox x:Name="HistoryList" SelectionChanged="HistoryList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Method}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource Text.Normal}" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayHost}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Text.Faint}" FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel x:Name="CollectionsArea" Visibility="Collapsed">
                        <StackPanel DockPanel.Dock="Bottom" Margin="8" >
                            <Button x:Name="SaveToCollectionButton" Content="Save current request…" Height="28"
                                    Click="SaveToCollectionButton_Click" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="NewFolderButton" Content="+ Folder" Height="26" FontSize="11" Padding="9,0"
                                        Click="NewFolderButton_Click"/>
                                <Button x:Name="RenameNodeButton" Content="Rename" Height="26" FontSize="11" Padding="9,0"
                                        Margin="6,0,0,0" Click="RenameNodeButton_Click"/>
                                <Button x:Name="DeleteNodeButton" Content="Delete" Height="26" FontSize="11" Padding="9,0"
                                        Margin="6,0,0,0" Click="DeleteNodeButton_Click"/>
                            </StackPanel>
                            <Button x:Name="ExportCollectionsButton" Content="Export as OpenAPI…" Height="26" FontSize="11"
                                    Margin="0,6,0,0" Click="ExportCollectionsButton_Click"
                                    ToolTip="Write the selected folder — or everything — as an OpenAPI 3.0 JSON file. Tokens and passwords are never written."/>
                        </StackPanel>
                        <TextBlock x:Name="CollectionsEmptyHint" DockPanel.Dock="Top" Margin="14,14,14,0"
                                   Foreground="{StaticResource Text.Faint}" FontSize="11" TextWrapping="Wrap"
                                   Text="No saved requests yet. Send a request, then “Save current request…” to keep it here."/>
                        <TreeView x:Name="CollectionsTree" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MouseDoubleClick="CollectionsTree_MouseDoubleClick"
                                  PreviewMouseRightButtonDown="CollectionsTree_PreviewMouseRightButtonDown">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Set website &amp; certificate…" Click="SetCollectionDefaults_Click"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding StatusSummary}">
                                        <TextBlock Text="{Binding MethodBadge}" FontSize="10" FontWeight="Bold" MinWidth="30"
                                                   Margin="0,0,7,0" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text.Normal}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="&#x25CF;" FontSize="8" Margin="7,0,0,0" VerticalAlignment="Center"
                                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Red}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsKnownGood}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ============ main area ============ -->
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>                <!-- request tab strip -->
                <RowDefinition Height="Auto"/>                <!-- website -->
                <RowDefinition Height="Auto"/>                <!-- certificate -->
                <RowDefinition Height="Auto"/>                <!-- request line -->
                <RowDefinition Height="*" MinHeight="188"/>   <!-- request config -->
                <RowDefinition Height="Auto"/>                <!-- splitter -->
                <RowDefinition x:Name="ResponseRow" Height="1.5*" MinHeight="190"/><!-- response -->
                <RowDefinition Height="Auto"/>                <!-- status -->
            </Grid.RowDefinitions>

            <!-- request tab strip -->
            <DockPanel Grid.Row="0" Margin="0,0,0,0">
                <Button x:Name="NewTabButton" DockPanel.Dock="Right" Width="34"
                        VerticalAlignment="Bottom" Margin="4,0,0,0" Click="NewTabButton_Click"
                        ToolTip="New request tab (Ctrl+T)">
                    <Path Data="M7,0.5 V13.5 M0.5,7 H13.5" Stroke="{StaticResource Text.Normal}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="ImportButton" DockPanel.Dock="Right" Content="Import &#x25BE;" Width="92"
                        VerticalAlignment="Bottom" Margin="4,0,0,0" Click="ImportButton_Click"
                        ToolTip="Import a request from a cURL command or an OpenAPI file, or save/load the whole workspace">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Paste cURL command…" Click="ImportCurl_Click"/>
                            <MenuItem Header="Import OpenAPI file…" Click="ImportOpenApi_Click"/>
                            <MenuItem Header="Import workspace…" Click="ImportWorkspace_Click"/>
                            <MenuItem Header="Export workspace…" Click="ExportWorkspace_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="DiscoverButton" DockPanel.Dock="Right" Content="Discover…" Width="92"
                        VerticalAlignment="Bottom" Margin="4,0,0,0" Click="DiscoverButton_Click"
                        ToolTip="Probe a wordlist of endpoints against this website to see which ones exist"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ListBox x:Name="TabStrip" Style="{StaticResource TabStripList}" VerticalAlignment="Bottom"
                             SelectionChanged="TabStrip_SelectionChanged"
                             ItemContainerStyle="{StaticResource TabStripItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="12,6,7,6">
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" MaxWidth="190"
                                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource Text.Soft}"/>
                                    <Button Content="&#x2715;" Tag="{Binding}" Click="CloseTab_Click"
                                            Style="{StaticResource MiniButton}" Width="20" Height="20" Margin="9,0,0,0"
                                            FontSize="11" ToolTip="Close tab (Ctrl+W)"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- website (base URL) row -->
            <DockPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="WEBSITE" Style="{StaticResource Caption}" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Width="92"/>
                <ComboBox x:Name="SavedBasesCombo" DockPanel.Dock="Right" Width="190" Margin="8,0,0,0"
                          SelectionChanged="SavedBasesCombo_SelectionChanged"/>
                <Button x:Name="ForgetBaseButton" DockPanel.Dock="Right" Content="Forget" Width="74" Margin="8,0,0,0"
                        Click="ForgetBaseButton_Click"/>
                <TextBox x:Name="BaseUrlBox" VerticalContentAlignment="Center"
                         TextChanged="BaseUrlBox_TextChanged"
                         Tag="https://internal.corp   (optional base URL)"
                         ToolTip="Base URL, e.g. https://internal.corp — the URL box below is appended to this. Leave blank to type full URLs."/>
            </DockPanel>

            <!-- cert row -->
            <DockPanel Grid.Row="2" Margin="0,0,0,8">
                <TextBlock Text="CERTIFICATE" Style="{StaticResource Caption}" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Width="92"/>
                <CheckBox x:Name="IgnoreServerCertCheck" DockPanel.Dock="Right"
                          Content="Ignore server cert errors (insecure)" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button x:Name="RefreshCertsButton" DockPanel.Dock="Right" Content="Refresh" Width="82" Margin="8,0,0,0"
                        Click="RefreshCertsButton_Click"/>
                <Button x:Name="LoadCertFileButton" DockPanel.Dock="Right" Content="From file…" Width="90" Margin="8,0,0,0"
                        Click="LoadCertFromFile_Click"
                        ToolTip="Load a client certificate from a .pfx/.p12 or .pem/.crt file (for this session)"/>
                <TextBox x:Name="CertFilter" DockPanel.Dock="Right" Width="140" Margin="8,0,0,0" Tag="filter…"
                         VerticalContentAlignment="Center" ToolTip="Filter certificates" TextChanged="CertFilter_TextChanged"/>
                <ComboBox x:Name="CertCombo" DisplayMemberPath="."/>
            </DockPanel>

            <!-- request line -->
            <DockPanel Grid.Row="3" Margin="0,0,0,8">
                <ComboBox x:Name="MethodCombo" DockPanel.Dock="Left" Width="92" SelectedIndex="0" Margin="0,0,8,0"
                          SelectionChanged="MethodCombo_SelectionChanged">
                    <ComboBoxItem>GET</ComboBoxItem>
                    <ComboBoxItem>POST</ComboBoxItem>
                    <ComboBoxItem>PUT</ComboBoxItem>
                    <ComboBoxItem>PATCH</ComboBoxItem>
                    <ComboBoxItem>DELETE</ComboBoxItem>
                    <ComboBoxItem>HEAD</ComboBoxItem>
                    <ComboBoxItem>OPTIONS</ComboBoxItem>
                </ComboBox>
                <Button x:Name="SendButton" DockPanel.Dock="Right" Content="Send" Width="94" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}" Click="SendButton_Click"/>
                <Button x:Name="CancelButton" DockPanel.Dock="Right" Content="Cancel" Width="78" Margin="8,0,0,0"
                        IsEnabled="False" Click="CancelButton_Click"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <TextBlock Text="TIMEOUT" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <TextBox x:Name="TimeoutBox" Width="56" Margin="6,0,0,0" Text="100"
                             VerticalContentAlignment="Center" ToolTip="Request timeout (seconds)"/>
                    <TextBlock Text="s" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{StaticResource Text.Muted}"/>
                </StackPanel>
                <TextBox x:Name="UrlBox" VerticalContentAlignment="Center" KeyDown="UrlBox_KeyDown"
                         TextChanged="UrlBox_TextChanged" LostFocus="UrlBox_LostFocus"
                         Tag="/api/resource   or a full https://… URL"
                         ToolTip="Path appended to the website above (e.g. /api/thing), or a full URL if no website is set."/>
            </DockPanel>

            <!-- request config tabs -->
            <TabControl Grid.Row="4">
                <TabItem Header="Params">
                    <DockPanel Margin="2">
                        <Button DockPanel.Dock="Bottom" x:Name="AddParamButton" Content="+ Add parameter" Width="140"
                                HorizontalAlignment="Left" Margin="8" Click="AddParamButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ParamsItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="key" VerticalContentAlignment="Center" ToolTip="Parameter name"/>
                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="value" Margin="6,0,0,0" VerticalContentAlignment="Center" ToolTip="Parameter value"/>
                                            <Button Grid.Column="3" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveParamButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Headers">
                    <DockPanel Margin="2">
                        <Button DockPanel.Dock="Bottom" x:Name="AddHeaderButton" Content="+ Add header" Width="120"
                                HorizontalAlignment="Left" Margin="8" Click="AddHeaderButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HeadersItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="Accept" VerticalContentAlignment="Center" ToolTip="Header name"/>
                                            <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="application/json" Margin="6,0,0,0" VerticalContentAlignment="Center" ToolTip="Header value"/>
                                            <Button Grid.Column="3" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveHeaderButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Body">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="BodyModeText" Content="Text" GroupName="BodyMode" IsChecked="True"
                                         VerticalAlignment="Center" Margin="0,0,14,0" Checked="BodyMode_Changed"/>
                            <RadioButton x:Name="BodyModeForm" Content="Form data (multipart)" GroupName="BodyMode"
                                         VerticalAlignment="Center" Checked="BodyMode_Changed"/>
                        </StackPanel>
                        <Grid>
                            <!-- text body -->
                            <DockPanel x:Name="TextBodyPanel">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="CONTENT-TYPE" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ContentTypeCombo" Width="260" Margin="8,0,0,0" SelectedIndex="0">
                                        <ComboBoxItem>application/json</ComboBoxItem>
                                        <ComboBoxItem>application/xml</ComboBoxItem>
                                        <ComboBoxItem>text/plain</ComboBoxItem>
                                        <ComboBoxItem>application/x-www-form-urlencoded</ComboBoxItem>
                                        <ComboBoxItem>(none)</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <TextBox x:Name="BodyBox" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                         Tag="{}{ &quot;example&quot;: &quot;request body&quot; }"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                            </DockPanel>
                            <!-- multipart form body -->
                            <DockPanel x:Name="FormBodyPanel" Visibility="Collapsed">
                                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,4" Foreground="{StaticResource Text.Faint}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Text="multipart/form-data — tick “File” and use “…” to upload a file; leave it unticked for a text field. The Content-Type and boundary are set for you."/>
                                <Button DockPanel.Dock="Bottom" x:Name="AddFormPartButton" Content="+ Add field" Width="120"
                                        HorizontalAlignment="Left" Margin="0,8,0,0" Click="AddFormPart_Click"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="FormItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="1.4*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                             Tag="field name" VerticalContentAlignment="Center"/>
                                                    <CheckBox Grid.Column="2" Content="File" IsChecked="{Binding IsFile}" Margin="8,0,0,0"
                                                              VerticalAlignment="Center" ToolTip="Upload the value as a file"/>
                                                    <TextBox Grid.Column="3" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             Tag="value or file path" Margin="6,0,0,0" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="4" Style="{StaticResource MiniButton}" Margin="6,0,0,0" Content="…"
                                                            Tag="{Binding}" Click="BrowseFormFile_Click" ToolTip="Choose a file to upload"/>
                                                    <Button Grid.Column="5" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                            Content="&#x2715;" Tag="{Binding}" Click="RemoveFormPart_Click" ToolTip="Remove"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Auth">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="TYPE" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="AuthTypeCombo" Width="180" SelectedIndex="0"
                                      SelectionChanged="AuthTypeCombo_SelectionChanged">
                                <ComboBoxItem>Auto (captured token)</ComboBoxItem>
                                <ComboBoxItem>None (never send auth)</ComboBoxItem>
                                <ComboBoxItem>Bearer token</ComboBoxItem>
                                <ComboBoxItem>Basic</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock x:Name="AutoAuthHint" FontSize="12" Foreground="{StaticResource Text.Muted}"
                                   TextWrapping="Wrap" Margin="60,0,0,8"
                                   Text="Sends the bearer token captured from this website's last auth response, when one exists. Other websites never receive it."/>
                        <StackPanel x:Name="BearerPanel" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                            <TextBlock Text="TOKEN" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                            <TextBox x:Name="BearerTokenBox" Width="520" VerticalContentAlignment="Center"
                                     Tag="paste your bearer token"/>
                        </StackPanel>
                        <StackPanel x:Name="BasicPanel" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="USER" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="BasicUserBox" Width="260" VerticalContentAlignment="Center" Tag="username"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PASS" Style="{StaticResource Caption}" VerticalAlignment="Center" Width="60"/>
                                <TextBox x:Name="BasicPassBox" Width="260" VerticalContentAlignment="Center" Tag="password"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Capture">
                    <DockPanel Margin="2">
                        <TextBlock DockPanel.Dock="Top" Margin="8,8,8,4" Foreground="{StaticResource Text.Faint}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Text="After sending, save a value from the response into a {{variable}} for later requests — e.g. Variable “token”, From Body, Path “access_token”. Reuse it as {{token}} in a Bearer token or any field."/>
                        <Button DockPanel.Dock="Bottom" x:Name="AddCaptureButton" Content="+ Add capture" Width="130"
                                HorizontalAlignment="Left" Margin="8" Click="AddCaptureButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CaptureItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding Variable, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="token" VerticalContentAlignment="Center" ToolTip="Variable name to save into"/>
                                            <ComboBox Grid.Column="2" Margin="6,0,0,0" Width="86" VerticalContentAlignment="Center"
                                                      SelectedIndex="{Binding Source, Converter={StaticResource CaptureSourceConverter}}"
                                                      ToolTip="Where to read the value from">
                                                <ComboBoxItem Content="Body"/>
                                                <ComboBoxItem Content="Header"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="3" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="access_token" Margin="6,0,0,0" VerticalContentAlignment="Center"
                                                     ToolTip="Body: dotted JSON path (data.access_token). Header: the header name."/>
                                            <Button Grid.Column="4" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveCaptureButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Tests">
                    <DockPanel Margin="2">
                        <TextBlock DockPanel.Dock="Top" Margin="8,8,8,4" Foreground="{StaticResource Text.Faint}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Text="Assert on the response so 'certapi run' and the suite can pass/fail — e.g. Status == 200, Body data.id exists, Time &lt; 500, Header Content-Type contains json. A request with no tests passes on any 2xx."/>
                        <Button DockPanel.Dock="Bottom" x:Name="AddAssertionButton" Content="+ Add test" Width="120"
                                HorizontalAlignment="Left" Margin="8" Click="AddAssertionButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AssertItems" Margin="8,8,8,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox Grid.Column="1" Width="96" VerticalContentAlignment="Center"
                                                      SelectedIndex="{Binding Target, Converter={StaticResource AssertTargetConverter}}"
                                                      ToolTip="What to check">
                                                <ComboBoxItem Content="Status"/>
                                                <ComboBoxItem Content="Time (ms)"/>
                                                <ComboBoxItem Content="Header"/>
                                                <ComboBoxItem Content="Body (JSON)"/>
                                                <ComboBoxItem Content="Body text"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="2" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="header name / JSON path" Margin="6,0,0,0" VerticalContentAlignment="Center"
                                                     ToolTip="Header: the header name. Body: dotted JSON path (data.id). Ignored for Status / Time / Body text."/>
                                            <ComboBox Grid.Column="3" Width="94" Margin="6,0,0,0" VerticalContentAlignment="Center"
                                                      SelectedIndex="{Binding Op, Converter={StaticResource AssertOpConverter}}"
                                                      ToolTip="Comparison">
                                                <ComboBoxItem Content="=="/>
                                                <ComboBoxItem Content="!="/>
                                                <ComboBoxItem Content="contains"/>
                                                <ComboBoxItem Content="matches"/>
                                                <ComboBoxItem Content="exists"/>
                                                <ComboBoxItem Content="absent"/>
                                                <ComboBoxItem Content="&lt;"/>
                                                <ComboBoxItem Content="&gt;"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="4" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Tag="expected value" Margin="6,0,0,0" VerticalContentAlignment="Center"
                                                     ToolTip="Expected value (ignored for exists / absent)."/>
                                            <Button Grid.Column="5" Style="{StaticResource MiniButton}" Margin="6,0,0,0"
                                                    Content="&#x2715;" Tag="{Binding}" Click="RemoveAssertionButton_Click" ToolTip="Remove"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
            </TabControl>

            <GridSplitter x:Name="ResponseSplitter" Grid.Row="5" Height="6" HorizontalAlignment="Stretch" Background="Transparent"
                          VerticalAlignment="Center"/>

            <!-- indeterminate "sending…" bar, overlaid on the top edge of the response area -->
            <ProgressBar x:Name="SendProgress" Grid.Row="6" Panel.ZIndex="5" Height="3"
                         VerticalAlignment="Top" HorizontalAlignment="Stretch" IsIndeterminate="True"
                         Visibility="Collapsed" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource Accent}"/>

            <!-- response -->
            <ContentControl x:Name="ResponseHost" Grid.Row="6" Focusable="False">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="RESPONSE" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBox x:Name="ResponseFindBox" Width="160" Height="26" Padding="7,0" Margin="0,0,6,0"
                                 VerticalContentAlignment="Center" Tag="find in response…" KeyDown="ResponseFindBox_KeyDown"
                                 ToolTip="Find text in the response (Enter for next)"/>
                        <Button x:Name="FindNextButton" Content="Find next" Height="26" FontSize="11" Padding="10,0"
                                Margin="0,0,6,0" Click="FindNext_Click"/>
                        <Button x:Name="PopOutButton" Height="26" Width="32" Padding="0" Margin="0,0,6,0"
                                FontFamily="Segoe MDL2 Assets" FontSize="12" Content="&#xE8A7;"
                                Click="PopOutButton_Click"
                                ToolTip="Open the response in its own window">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open this view in a window" Click="PopOutView_Click"/>
                                    <MenuItem Header="Open the whole response panel in a window" Click="PopOutPanel_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="CopyBodyButton" Content="Copy body" Height="26" FontSize="11" Padding="10,0"
                                Margin="0,0,6,0" Click="CopyBodyButton_Click"/>
                        <Button x:Name="CopyCurlButton" Content="Copy as &#x25BE;" Height="26" FontSize="11" Padding="10,0"
                                Margin="0,0,6,0" Click="CopyCodeButton_Click"
                                ToolTip="Copy this request as a code snippet">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="cURL" Tag="curl" Click="CopyAs_Click"/>
                                    <MenuItem Header="PowerShell" Tag="powershell" Click="CopyAs_Click"/>
                                    <MenuItem Header="Python (requests)" Tag="python" Click="CopyAs_Click"/>
                                    <MenuItem Header="C# (HttpClient)" Tag="csharp" Click="CopyAs_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button x:Name="SaveResponseButton" Content="Save…" Height="26" FontSize="11" Padding="10,0"
                                Click="SaveResponseButton_Click"/>
                    </StackPanel>
                </Grid>
                <TabControl x:Name="ResponseTabs" SelectionChanged="ResponseTabs_SelectionChanged">
                    <TabItem Header="Pretty">
                        <RichTextBox x:Name="PrettyRich" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"/>
                    </TabItem>
                    <TabItem Header="Raw">
                        <TextBox x:Name="RawBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="The raw response body appears here after you send a request."
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                    <TabItem Header="Headers">
                        <TextBox x:Name="ResponseHeadersBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="Response headers appear here after you send a request."
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <TextBox x:Name="DiagnosticsBox" IsReadOnly="True" AcceptsReturn="True" BorderThickness="0"
                                 Tag="TLS and certificate details appear here after a request."
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="10"/>
                    </TabItem>
                    <TabItem Header="Rendered">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{StaticResource Bg.Window}" Padding="8,6"
                                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button x:Name="RenderReloadButton" DockPanel.Dock="Right" Content="Reload" Height="26"
                                            FontSize="11" Padding="10,0" Margin="8,0,0,0" Click="RenderReloadButton_Click"/>
                                    <TextBlock x:Name="RenderUrlText" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource Text.Muted}" FontSize="11"
                                               Text="Opens the current request's URL as a web page — every resource is fetched with your client certificate."/>
                                </DockPanel>
                            </Border>
                            <Grid>
                                <wv2:WebView2 x:Name="Browser"/>
                                <TextBlock x:Name="RenderHint" IsHitTestVisible="False" TextWrapping="Wrap" MaxWidth="520"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                           Foreground="{StaticResource Text.Faint}" FontSize="12"
                                           Text="Enter a URL in the request above, then this tab renders that page — authenticated with your selected certificate."/>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Network">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="56"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="NetworkDetailRow" Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="38" Background="{StaticResource Bg.Window}" Padding="10,0">
                                <DockPanel LastChildFill="False">
                                    <TextBox x:Name="NetworkSearchBox" DockPanel.Dock="Left" Width="170" Height="26" Padding="7,0"
                                             VerticalContentAlignment="Center" VerticalAlignment="Center" FontSize="11"
                                             Tag="filter…" TextChanged="NetworkSearch_TextChanged"
                                             ToolTip="Filter by URL, method, status, or content type"/>
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <Button x:Name="NetClassAll" Content="All" Style="{StaticResource SideTab}" Tag="active" Margin="0,0,8,0" Click="NetworkClass_Click"/>
                                        <Button x:Name="NetClass2xx" Content="2xx" Style="{StaticResource SideTab}" Margin="0,0,8,0" Click="NetworkClass_Click"/>
                                        <Button x:Name="NetClass3xx" Content="3xx" Style="{StaticResource SideTab}" Margin="0,0,8,0" Click="NetworkClass_Click"/>
                                        <Button x:Name="NetClass4xx" Content="4xx" Style="{StaticResource SideTab}" Margin="0,0,8,0" Click="NetworkClass_Click"/>
                                        <Button x:Name="NetClass5xx" Content="5xx" Style="{StaticResource SideTab}" Margin="0,0,8,0" Click="NetworkClass_Click"/>
                                        <Button x:Name="NetClassErr" Content="ERR" Style="{StaticResource SideTab}" Click="NetworkClass_Click"/>
                                    </StackPanel>
                                    <CheckBox x:Name="NetworkCertOnly" DockPanel.Dock="Left" Content="cert only" VerticalAlignment="Center"
                                              Margin="12,0,0,0" FontSize="11" Foreground="{StaticResource Text.Muted}"
                                              Click="NetworkFilter_Changed"
                                              ToolTip="Show only calls made with your client certificate"/>
                                    <Button x:Name="ClearNetworkButton" DockPanel.Dock="Right" Content="Clear" VerticalAlignment="Center"
                                            Height="24" FontSize="11" Padding="10,0" Click="ClearNetworkButton_Click"/>
                                    <TextBlock x:Name="NetworkCountText" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,12,0"
                                               Foreground="{StaticResource Text.Muted}" FontSize="11" Text="No requests yet."/>
                                </DockPanel>
                            </Border>
                            <Border Grid.Row="1" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border}"
                                    BorderThickness="0,1,0,1" Padding="10,5,10,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="52"/>
                                        <ColumnDefinition Width="116"/>
                                        <ColumnDefinition Width="72"/>
                                        <ColumnDefinition Width="62"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="METHOD" Style="{StaticResource Caption}" FontSize="10"/>
                                    <TextBlock Grid.Column="2" Text="STAT" Style="{StaticResource Caption}" FontSize="10"/>
                                    <TextBlock Grid.Column="3" Text="TYPE" Style="{StaticResource Caption}" FontSize="10"/>
                                    <TextBlock Grid.Column="4" Text="SIZE" Style="{StaticResource Caption}" FontSize="10"/>
                                    <TextBlock Grid.Column="5" Text="TIME" Style="{StaticResource Caption}" FontSize="10"/>
                                    <TextBlock Grid.Column="6" Text="URL" Style="{StaticResource Caption}" FontSize="10"/>
                                </Grid>
                            </Border>
                            <GridSplitter x:Name="NetworkSplitter" Grid.Row="3" Height="4" HorizontalAlignment="Stretch"
                                          Background="{StaticResource Border}" Visibility="Collapsed" Focusable="False"
                                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>
                            <Border Grid.Row="4" x:Name="NetworkDetailPane" Visibility="Collapsed"
                                    Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="10,4">
                                        <DockPanel>
                                            <Button x:Name="NetworkDetailClose" DockPanel.Dock="Right" Style="{StaticResource MiniButton}"
                                                    Width="22" Height="22" FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;"
                                                    ToolTip="Close details" Click="NetworkDetailClose_Click"/>
                                            <Button x:Name="NetworkDetailCopy" DockPanel.Dock="Right" Content="Copy" Height="22" FontSize="11"
                                                    Padding="10,0" Margin="0,0,8,0" Click="NetworkDetailCopy_Click"
                                                    ToolTip="Copy these details to the clipboard"/>
                                            <TextBlock x:Name="NetworkDetailTitle" Style="{StaticResource Caption}" FontSize="10"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="NetworkDetailHost" Margin="10,8,10,10"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                            <ListBox x:Name="NetworkList" Grid.Row="2" SelectionChanged="NetworkList_SelectionChanged"
                                     PreviewMouseRightButtonDown="NetworkList_PreviewMouseRightButtonDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <Setter Property="Padding" Value="10,4"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy URL" Click="NetworkCopyUrl_Click"/>
                                        <MenuItem Header="Copy as cURL" Click="NetworkCopyCurl_Click"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="116"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="62"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#x25CF;" FontSize="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{StaticResource Accent}" ToolTip="Fetched with your client certificate"
                                                       Visibility="{Binding UsedClientCert, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Method}" FontWeight="Bold" FontSize="10.5"
                                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding StatusLabel}" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{Binding Converter={StaticResource StatusBrush}}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding ShortType}" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Text.Muted}" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
                                            <TextBlock Grid.Column="4" Text="{Binding SizeLabel}" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Text.Muted}"/>
                                            <TextBlock Grid.Column="5" Text="{Binding TimeLabel}" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Text.Muted}"/>
                                            <TextBlock Grid.Column="6" Text="{Binding Url}" FontSize="11.5" VerticalAlignment="Center"
                                                       Foreground="{StaticResource Text.Soft}" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
            </DockPanel>
            </ContentControl>

            <!-- status bar -->
            <Border Grid.Row="7" Margin="0,8,0,0" Background="{StaticResource Bg.Panel}" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <DockPanel>
                    <Button x:Name="SelfTestButton" Content="Run Self-Test" Width="118"
                            DockPanel.Dock="Right" Click="SelfTestButton_Click"/>
                    <Border x:Name="TokenChip" DockPanel.Dock="Right" Visibility="Collapsed" Margin="0,0,10,0"
                            VerticalAlignment="Center" Background="{StaticResource Bg.Input}"
                            BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10"
                            Padding="10,3" Cursor="Hand" MouseLeftButtonUp="TokenChip_Click"
                            ToolTip="A bearer token was captured for this website — click for details">
                        <TextBlock x:Name="TokenChipText" FontSize="12" Foreground="{StaticResource Text.Soft}"/>
                    </Border>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{StaticResource Text.Soft}"
                               TextTrimming="CharacterEllipsis" Text="Ready."/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
