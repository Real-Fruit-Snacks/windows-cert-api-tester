<Window x:Class="ApiTester.App.SessionCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Capture session" Width="1040" Height="720" MinWidth="720" MinHeight="480"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg.Window}" Foreground="{DynamicResource Text.Soft}"
        FontFamily="{StaticResource Mono}" FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Height="40" Background="{DynamicResource Bg.Panel}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="&#x276F;" Foreground="{DynamicResource Accent}" FontWeight="Bold" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="CAPTURE SESSION" Margin="9,0,0,0" FontWeight="Bold" FontSize="13"
                                   Foreground="{DynamicResource Text.Normal}" VerticalAlignment="Center"/>
                        <TextBlock Margin="12,0,0,0" FontSize="11" Foreground="{DynamicResource Text.Muted}"
                                   VerticalAlignment="Center"
                                   Text="log in on the site itself — this captures the session, never your password"/>
                    </StackPanel>
                    <Button Content="&#xE8BB;" HorizontalAlignment="Right" Style="{StaticResource CaptionClose}"
                            Height="40" Click="Cancel_Click" ToolTip="Cancel"/>
                </Grid>
            </Border>

            <!-- Address bar -->
            <DockPanel Grid.Row="1" Margin="14,12,14,6">
                <Button x:Name="FinishButton" DockPanel.Dock="Right" Content="Finish &amp; save" Width="120"
                        Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Click="Finish_Click"/>
                <Button DockPanel.Dock="Left" Content="&#x2039;" Width="30" Click="Back_Click" ToolTip="Back"/>
                <Button DockPanel.Dock="Left" Content="&#x203A;" Width="30" Margin="4,0,0,0" Click="Forward_Click" ToolTip="Forward"/>
                <Button DockPanel.Dock="Left" Content="&#x21bb;" Width="30" Margin="4,0,8,0" Click="Reload_Click" ToolTip="Reload"/>
                <TextBox x:Name="AddressBox" VerticalContentAlignment="Center" Padding="8,6"
                         KeyDown="AddressBox_KeyDown" ToolTip="Type a login URL and press Enter"/>
            </DockPanel>

            <!-- Live capture panel -->
            <Border Grid.Row="2" Margin="14,0,14,6" Background="{DynamicResource Bg.Input}" BorderBrush="{DynamicResource Border}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <TextBlock x:Name="CaptureSummary" FontSize="11" Foreground="{DynamicResource Text.Muted}"
                           TextWrapping="Wrap" Text="Nothing captured yet — navigate to a site and log in."/>
            </Border>

            <!-- Browser -->
            <Border Grid.Row="3" Margin="14,0,14,14" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                <wv2:WebView2 x:Name="Browser"/>
            </Border>
        </Grid>
    </Border>
</Window>
