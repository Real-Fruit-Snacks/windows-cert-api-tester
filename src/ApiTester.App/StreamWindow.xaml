<Window x:Class="ApiTester.App.StreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Live stream" Width="760" Height="560" MinWidth="520" MinHeight="360"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Bg.Window}" Foreground="{DynamicResource Text.Soft}"
        FontFamily="{StaticResource Mono}" FontSize="12.5"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource Bg.Panel}" Padding="14,10"
                    MouseLeftButtonDown="Header_Drag">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="&#x2715;" Width="30" Height="26"
                            Click="Close_Click" ToolTip="Close"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x276F;" Foreground="{DynamicResource Accent}" FontWeight="Bold"
                                   FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="LIVE STREAM" Margin="9,0,0,0" FontWeight="Bold" FontSize="13"
                                   Foreground="{DynamicResource Text.Normal}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ModeText" Margin="12,0,0,0" FontSize="11"
                                   Foreground="{DynamicResource Text.Muted}" VerticalAlignment="Center"
                                   Text="WebSocket (ws/wss) or Server-Sent Events (http/https)"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- URL row -->
            <DockPanel Grid.Row="1" Margin="14,12,14,6">
                <Button x:Name="ConnectButton" DockPanel.Dock="Right" Content="Connect" Width="96"
                        Margin="8,0,0,0" Style="{StaticResource PrimaryButton}" Click="Connect_Click"/>
                <Button x:Name="DisconnectButton" DockPanel.Dock="Right" Content="Disconnect" Width="96"
                        Margin="8,0,0,0" IsEnabled="False" Click="Disconnect_Click"/>
                <TextBox x:Name="UrlBox" VerticalContentAlignment="Center" Padding="10,7"
                         KeyDown="UrlBox_KeyDown"
                         ToolTip="wss://host/socket for a WebSocket, or https://host/events for SSE"/>
            </DockPanel>

            <TextBlock x:Name="StatusText" Grid.Row="1" Margin="14,0,220,0" VerticalAlignment="Bottom"
                       Visibility="Collapsed" FontSize="11" Foreground="{DynamicResource Text.Muted}"/>

            <!-- Transcript -->
            <TextBox x:Name="Transcript" Grid.Row="2" Margin="14,6,14,6" IsReadOnly="True"
                     AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto" Background="{DynamicResource Bg.Input}"
                     Foreground="{DynamicResource Text.Soft}" BorderBrush="{DynamicResource Border}"
                     BorderThickness="1" Padding="10"/>

            <!-- Message input (WebSocket) -->
            <DockPanel Grid.Row="3" Margin="14,0,14,14">
                <Button x:Name="SendButton" DockPanel.Dock="Right" Content="Send" Width="96"
                        Margin="8,0,0,0" IsEnabled="False" Style="{StaticResource PrimaryButton}"
                        Click="Send_Click"/>
                <Button x:Name="ClearButton" DockPanel.Dock="Left" Content="Clear" Width="70"
                        Margin="0,0,8,0" Click="Clear_Click" ToolTip="Clear the transcript"/>
                <TextBox x:Name="MessageBox" VerticalContentAlignment="Center" Padding="10,7"
                         IsEnabled="False" KeyDown="MessageBox_KeyDown"
                         ToolTip="Type a message and press Enter to send (WebSocket only)"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
